# --- REQUIRED: Vercel / Production Keys ---
# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_service_role_or_anon_key
# Note: Code also supports SUPABASE_SERVICE_ROLE_KEY or SUPABASE_ANON_KEY as aliases

# AI Services
OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key

# --- OPTIONAL: Advanced Configuration ---
# OpenAI Customization
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Search Tuning
SEMANTIC_SEARCH_THRESHOLD=0.1
SEMANTIC_SEARCH_SCAN_LIMIT=2000
SEMANTIC_SEARCH_ALWAYS_RETURN_RESULTS=false
